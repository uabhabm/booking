# MySQL — server-only (SvelteKit load/actions). Apply tables: mysql -u USER -p DATABASE < schema.sql
#
# Option A: single URL (password special chars must be URL-encoded)
# DATABASE_URL=mysql://user:password@127.0.0.1:3306/booking
#
# Option B: discrete variables
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=booking
# MYSQL_PASSWORD=
# MYSQL_DATABASE=booking

DATABASE_URL=

# Routes: / lists objects; /<object id from bookable_objects.id> is the calendar (?vecka=YYYY-MM-DD for week).
# Swish (only when booking_price > 0). MSS CPC: https://developer.swish.nu — QR commerce: https://developer.swish.nu/api/qr-codes
# MSS uses mTLS: default PEM/key/CA under client_cert/ (Swish_Merchant_TestCertificate_1234679304 + Swish_TLS_RootCA.pem).
# SWISH_MSS_PAYMENT_REQUESTS_URL=https://mss.cpc.getswish.net/swish-cpcapi/api/v1/paymentrequests/
# SWISH_CLIENT_CERT_PATH=
# SWISH_CLIENT_KEY_PATH=
# SWISH_TLS_ROOT_CA_PATH=
# SWISH_PAYEE_ALIAS=1234679304
# SWISH_CALLBACK_URL=https://your-public-host.example/swish/callback
# SWISH_QR_COMMERCE_URL=https://mpc.getswish.net/qrg-swish/api/v1/commerce

# Tables: bookable_objects (id, name, booking_price, total_to_pay_label); bookings (…, booking_price, swish_payment_request_uuid) — see schema.sql and schema-migration-*.sql
